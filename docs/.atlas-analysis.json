  "keyFeatures": [
    "Unified MCP gateway exposing all registered MCP servers through a single /mcp endpoint",
    "Support for both Streamable HTTP and STDIO MCP server transports",
    "Tool Groups for exposing subsets of tools to specific MCP clients",
    "Enterprise mode with Access Control Lists (ACLs) for per-client server access",
    "Stateful and stateless connection modes to handle cold-start latency",
    "Bearer token and custom header authentication for upstream MCP servers",
    "OpenTelemetry/Prometheus metrics for observability",
    "SQLite (dev) and PostgreSQL (production) database support",
    "Self-hosted with Docker Compose and minimal container image",
    "MCP Prompts support for registering and retrieving prompts from MCP servers"
  ],
  "publicApiSurface": [
    "GET /health",
    "GET /metadata",
    "POST /init",
    "ANY /mcp (Streamable HTTP MCP proxy)",
    "ANY /sse (SSE MCP proxy)",
    "GET /v0/groups/:name/mcp",
